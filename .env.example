# Copy to .env and fill in values before running.

# Path to the DuckDB database file.
CADENCE_DB_PATH=/opt/airflow/data/cadence.duckdb

# Directory where the generator writes staging CSV files.
CADENCE_DATA_DIR=/tmp/cadence

# Discord webhook URL for failure alerts.
# Leave blank to disable Discord alerts (failures are still logged).
CADENCE_DISCORD_WEBHOOK_URL=

# Airflow UID (set to your local UID on Linux/Mac: echo $(id -u))
AIRFLOW_UID=50000
